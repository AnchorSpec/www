---
const allMdFiles = import.meta.glob('../../../docs/**/*.md');

export async function getStaticPaths() {
  const files = import.meta.glob('../../../docs/**/*.md');
  return Object.keys(files).flatMap(path => {
    const m = path.match(/\/docs\/(v[\d.]+)\/([^/]+)\.md$/);
    return m ? [{ params: { version: m[1], slug: m[2] } }] : [];
  });
}

const { version, slug } = Astro.params;

const currentKey = Object.keys(allMdFiles).find(p =>
  p.endsWith(`/docs/${version}/${slug}.md`)
);

const mod = await allMdFiles[currentKey!]() as { default: any };
const Content = mod.default;

const DOC_ORDER = [
  'getting-started', 'installation', 'concepts', 'cli', 'commands',
  'workflows', 'customization', 'multi-language', 'supported-tools',
  'migration-guide', 'opsx', 'ansx',
];

const DOC_GROUPS = [
  { label: 'Start here', slugs: ['getting-started', 'installation', 'concepts'] },
  { label: 'Reference',  slugs: ['cli', 'commands', 'workflows', 'customization'] },
  { label: 'Guides',     slugs: ['multi-language', 'supported-tools', 'migration-guide', 'opsx', 'ansx'] },
];

const sidebarItems = Object.keys(allMdFiles)
  .filter(p => p.includes(`/docs/${version}/`))
  .map(p => ({
    slug: p.match(/\/([^/]+)\.md$/)![1],
    label: p.match(/\/([^/]+)\.md$/)![1]
      .replace(/-/g, ' ')
      .replace(/\b\w/g, (c: string) => c.toUpperCase()),
  }))
  .sort((a, b) => {
    const ai = DOC_ORDER.indexOf(a.slug);
    const bi = DOC_ORDER.indexOf(b.slug);
    if (ai < 0 && bi < 0) return a.label.localeCompare(b.label);
    if (ai < 0) return 1;
    if (bi < 0) return -1;
    return ai - bi;
  });

const slugToGroup = new Map<string, string>();
for (const g of DOC_GROUPS) for (const s of g.slugs) slugToGroup.set(s, g.label);

const groupedSidebar = DOC_GROUPS.map(g => ({
  label: g.label,
  items: sidebarItems.filter(item => g.slugs.includes(item.slug)),
})).filter(g => g.items.length > 0);

const ungroupedItems = sidebarItems.filter(item => !slugToGroup.has(item.slug));

const VERSIONS = [
  { value: 'v1.3.1', label: 'latest (v1.3.1)' },
  { value: 'v1.3.0', label: 'v1.3.0' },
];

const base = import.meta.env.BASE_URL;
const pageTitle = slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${base}favicon.ico`} />
    <title>{pageTitle} — AnchorSpec Docs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #07111f;
        --bg-1: #0b1828;
        --bg-2: #0e1d31;
        --line: rgba(168, 197, 220, 0.10);
        --line-strong: rgba(168, 197, 220, 0.18);
        --text: #e6eef8;
        --text-2: #a6b8cc;
        --text-3: #6e8499;
        --anchor: #a8c5dc;
        --accent: #5ba3e8;
        --accent-2: #8ac4ff;
      }

      *::-webkit-scrollbar { width: 10px; height: 10px; }
      *::-webkit-scrollbar-track { background: transparent; }
      *::-webkit-scrollbar-thumb { background: rgba(168,197,220,0.12); border-radius: 8px; }
      *::-webkit-scrollbar-thumb:hover { background: rgba(168,197,220,0.2); }
      ::selection { background: rgba(91,163,232,0.35); color: #fff; }

      html { height: 100%; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Geist', 'Inter Tight', system-ui, -apple-system, sans-serif;
        font-feature-settings: "ss01", "cv11";
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      code, pre {
        font-family: 'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace;
        font-feature-settings: "calt", "ss02";
      }

      /* ── Header ── */
      header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(12px) saturate(140%);
        background: rgba(7,17,31,0.80);
        border-bottom: 1px solid var(--line);
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        height: 52px;
      }

      .header-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .logo {
        font-weight: 600;
        font-size: 15px;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.015em;
        white-space: nowrap;
      }
      .logo:hover { color: var(--text); }

      .nav-sep { color: var(--line-strong); padding: 0 2px; }

      .nav-docs {
        color: var(--text-2);
        text-decoration: none;
        font-size: 14px;
      }
      .nav-docs:hover { color: var(--text); }

      select#version-select {
        background: var(--bg-2);
        border: 1px solid var(--line-strong);
        color: var(--text-2);
        padding: 0.3rem 0.6rem;
        border-radius: 7px;
        font-size: 13px;
        cursor: pointer;
        outline: none;
        font-family: inherit;
        transition: border-color .15s ease;
      }
      select#version-select:hover { border-color: rgba(168,197,220,0.32); color: var(--text); }
      select#version-select:focus { border-color: var(--accent); }

      /* ── Layout ── */
      .layout {
        display: flex;
        flex: 1;
      }

      /* ── Sidebar toggle ── */
      .sidebar-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        color: var(--text-2);
        cursor: pointer;
        padding: 0.25rem 0.4rem;
        border-radius: 6px;
        flex-shrink: 0;
        transition: background .12s ease, color .12s ease;
      }
      .sidebar-toggle:hover { background: rgba(255,255,255,0.04); color: var(--text); }

      /* ── Sidebar overlay backdrop (mobile) ── */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        top: 52px;
        background: rgba(0, 0, 0, 0.6);
        z-index: 19;
      }
      .sidebar-overlay.visible { display: block; }

      /* ── Sidebar ── */
      aside {
        width: 228px;
        flex-shrink: 0;
        border-right: 1px solid var(--line);
        position: sticky;
        top: 52px;
        height: calc(100vh - 52px);
        overflow-y: auto;
        padding: 20px 0 40px;
        transition: width 0.2s ease, padding 0.2s ease, border 0.2s ease;
      }

      aside.collapsed {
        width: 0;
        overflow: hidden;
        padding: 0;
        border-right: none;
      }

      @media (max-width: 767px) {
        aside {
          position: fixed;
          top: 52px;
          left: 0;
          height: calc(100vh - 52px);
          z-index: 20;
          background: var(--bg);
          transform: translateX(-100%);
          transition: transform 0.25s ease;
          width: 228px !important;
          overflow-y: auto !important;
          padding: 20px 0 40px !important;
          border-right: 1px solid var(--line) !important;
        }
        aside.open { transform: translateX(0); }
      }

      /* ── Sidebar nav ── */
      .sidebar-group { margin-bottom: 22px; }
      .sidebar-group-title {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-3);
        padding: 0 18px 8px;
      }

      aside nav { display: flex; flex-direction: column; }

      aside nav a {
        display: block;
        padding: 7px 18px;
        font-size: 13.5px;
        color: var(--text-2);
        text-decoration: none;
        border-left: 2px solid transparent;
        transition: color 0.1s, background 0.1s, border-color 0.1s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      aside nav a:hover { color: var(--text); background: rgba(255,255,255,0.03); }
      aside nav a.active {
        color: var(--text);
        background: rgba(91,163,232,0.08);
        border-left-color: var(--accent);
        font-weight: 500;
      }

      /* ── Main content ── */
      main {
        flex: 1;
        min-width: 0;
        padding: 2.5rem 3rem 4rem;
      }

      article { max-width: 820px; }

      /* ── Prose ── */
      .prose :global(h1) {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.025em;
        margin-bottom: 0.75rem;
        color: var(--text);
      }

      .prose :global(h2) {
        font-size: 1.25rem;
        font-weight: 600;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--line);
        letter-spacing: -0.018em;
      }

      .prose :global(h3) {
        font-size: 1rem;
        font-weight: 600;
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
        letter-spacing: -0.012em;
      }

      .prose :global(h4),
      .prose :global(h5),
      .prose :global(h6) {
        font-size: 0.9rem;
        font-weight: 600;
        margin-top: 1.25rem;
        margin-bottom: 0.4rem;
      }

      .prose :global(p) {
        line-height: 1.75;
        margin-bottom: 1rem;
        color: var(--text-2);
      }

      .prose :global(a) { color: var(--accent-2); text-decoration: none; }
      .prose :global(a:hover) { color: var(--accent); text-decoration: underline; }

      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
        color: var(--text-2);
      }

      .prose :global(li) { line-height: 1.75; margin-bottom: 0.2rem; }
      .prose :global(li > ul),
      .prose :global(li > ol) { margin-bottom: 0; }

      .prose :global(code) {
        background: var(--bg-2);
        border: 1px solid var(--line);
        border-radius: 5px;
        padding: 0.1em 0.4em;
        font-size: 0.85em;
        color: var(--anchor);
      }

      .prose :global(pre) {
        background: var(--bg-1) !important;
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 1.25rem;
        overflow-x: auto;
        margin-bottom: 1.25rem;
        line-height: 1.7;
      }

      .prose :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.875rem;
        color: var(--text);
      }

      .prose :global(blockquote) {
        border-left: 3px solid var(--accent);
        padding: 0.25rem 0 0.25rem 1rem;
        margin: 1.25rem 0;
        color: var(--text-2);
        font-style: italic;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--line);
        margin: 2rem 0;
      }

      .prose :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.25rem;
        font-size: 0.9rem;
      }

      .prose :global(th) {
        background: var(--bg-2);
        border: 1px solid var(--line);
        padding: 0.5rem 0.75rem;
        text-align: left;
        font-weight: 600;
        color: var(--text);
      }

      .prose :global(td) {
        border: 1px solid var(--line);
        padding: 0.5rem 0.75rem;
        color: var(--text-2);
      }

      .prose :global(tr:nth-child(even) td) { background: rgba(255,255,255,0.02); }
      .prose :global(img) { max-width: 100%; border-radius: 6px; }
      .prose :global(strong) { font-weight: 600; color: var(--text); }
    </style>
  </head>
  <body>
    <header>
      <div class="header-left">
        <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation" aria-expanded="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <rect y="3" width="18" height="1.5" rx="0.75"/>
            <rect y="8.25" width="18" height="1.5" rx="0.75"/>
            <rect y="13.5" width="18" height="1.5" rx="0.75"/>
          </svg>
        </button>
        <a class="logo" href={base}>⚓ AnchorSpec</a>
        <span class="nav-sep">/</span>
        <a class="nav-docs" href={`${base}docs/v1.3.1/getting-started`}>Docs</a>
      </div>
      <select id="version-select">
        {VERSIONS.map(v => (
          <option value={v.value} selected={v.value === version}>{v.label}</option>
        ))}
      </select>
    </header>

    <div id="sidebar-overlay" class="sidebar-overlay"></div>
    <div class="layout">
      <aside>
        <nav>
          {groupedSidebar.map(group => (
            <div class="sidebar-group">
              <div class="sidebar-group-title">{group.label}</div>
              {group.items.map(item => (
                <a
                  href={`${base}docs/${version}/${item.slug}`}
                  class={item.slug === slug ? 'active' : ''}
                >
                  {item.label}
                </a>
              ))}
            </div>
          ))}
          {ungroupedItems.map(item => (
            <a
              href={`${base}docs/${version}/${item.slug}`}
              class={item.slug === slug ? 'active' : ''}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </aside>

      <main>
        <article class="prose">
          <Content />
        </article>
      </main>
    </div>

    <script define:vars={{ base, slug, version }}>
      document.getElementById('version-select')?.addEventListener('change', (e) => {
        window.location.href = `${base}docs/${e.target.value}/${slug}`;
      });

      const sidebarToggle = document.getElementById('sidebar-toggle');
      const sidebar = document.querySelector('aside');
      const overlay = document.getElementById('sidebar-overlay');

      function isMobile() { return window.innerWidth < 768; }

      // Restore desktop collapsed preference
      if (!isMobile() && localStorage.getItem('sidebar-collapsed') === '1') {
        sidebar?.classList.add('collapsed');
        sidebarToggle?.setAttribute('aria-expanded', 'false');
      }

      sidebarToggle?.addEventListener('click', () => {
        if (isMobile()) {
          const isOpen = sidebar?.classList.toggle('open');
          overlay?.classList.toggle('visible', isOpen);
          sidebarToggle?.setAttribute('aria-expanded', String(isOpen));
        } else {
          const isCollapsed = sidebar?.classList.toggle('collapsed');
          sidebarToggle?.setAttribute('aria-expanded', String(!isCollapsed));
          localStorage.setItem('sidebar-collapsed', isCollapsed ? '1' : '0');
        }
      });

      overlay?.addEventListener('click', () => {
        sidebar?.classList.remove('open');
        overlay?.classList.remove('visible');
        sidebarToggle?.setAttribute('aria-expanded', 'false');
      });

      window.addEventListener('resize', () => {
        if (!isMobile()) {
          sidebar?.classList.remove('open');
          overlay?.classList.remove('visible');
        }
      });
    </script>
  </body>
</html>
