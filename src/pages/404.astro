---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — AnchorSpec"
  description="Page not found."
>
  <section style="position:relative;overflow:hidden;padding:120px 0 100px;min-height:60vh;display:flex;align-items:center;">
    <div class="hero-bg"></div>
    <div class="container" style="position:relative;z-index:1;text-align:center;">

      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--text-3);margin-bottom:24px;">
        404
      </div>

      <div style="display:flex;justify-content:center;margin-bottom:28px;">
        <span style="font-size:72px;line-height:1;filter:drop-shadow(0 8px 32px rgba(91,163,232,0.18));opacity:0.6;" role="img" aria-label="anchor">⚓</span>
      </div>

      <h1 style="font-size:clamp(28px,4vw,42px);margin-bottom:16px;">
        Page not found
      </h1>

      <p style="max-width:440px;margin:0 auto 36px;color:var(--text-2);font-size:16px;line-height:1.6;">
        This anchor found no bottom. The page may have moved, been renamed, or never existed.
      </p>

      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a class="btn btn-primary" href="/">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M12 5l-7 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Back to home
        </a>
        <a class="btn btn-ghost" href="/docs/v1.3.1/getting-started">
          Docs
        </a>
      </div>

    </div>
  </section>
</BaseLayout>
