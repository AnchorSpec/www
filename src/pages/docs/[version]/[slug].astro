---
const allMdFiles = import.meta.glob('../../../docs/**/*.md');

export async function getStaticPaths() {
  const files = import.meta.glob('../../../docs/**/*.md');
  return Object.keys(files).flatMap(path => {
    const m = path.match(/\/docs\/(v[\d.]+)\/([^/]+)\.md$/);
    return m ? [{ params: { version: m[1], slug: m[2] } }] : [];
  });
}

const { version, slug } = Astro.params;

const currentKey = Object.keys(allMdFiles).find(p =>
  p.endsWith(`/docs/${version}/${slug}.md`)
);

const mod = await allMdFiles[currentKey!]() as { default: any };
const Content = mod.default;

const DOC_ORDER = [
  'getting-started', 'installation', 'concepts', 'cli', 'commands',
  'workflows', 'customization', 'multi-language', 'supported-tools',
  'migration-guide', 'opsx', 'ansx',
];

const sidebarItems = Object.keys(allMdFiles)
  .filter(p => p.includes(`/docs/${version}/`))
  .map(p => ({
    slug: p.match(/\/([^/]+)\.md$/)![1],
    label: p.match(/\/([^/]+)\.md$/)![1]
      .replace(/-/g, ' ')
      .replace(/\b\w/g, (c: string) => c.toUpperCase()),
  }))
  .sort((a, b) => {
    const ai = DOC_ORDER.indexOf(a.slug);
    const bi = DOC_ORDER.indexOf(b.slug);
    if (ai < 0 && bi < 0) return a.label.localeCompare(b.label);
    if (ai < 0) return 1;
    if (bi < 0) return -1;
    return ai - bi;
  });

const VERSIONS = [
  { value: 'v1.3.1', label: 'latest (v1.3.1)' },
  { value: 'v1.3.0', label: 'v1.3.0' },
];

const base = import.meta.env.BASE_URL;
const pageTitle = slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${base}favicon.ico`} />
    <title>{pageTitle} — AnchorSpec Docs</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0d1117;
        --surface: #161b22;
        --border: #30363d;
        --accent: #58a6ff;
        --text: #e6edf3;
        --muted: #8b949e;
      }

      html { height: 100%; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── Header ── */
      header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        padding: 0.65rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        height: 49px;
      }

      .header-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .logo {
        font-weight: 700;
        font-size: 1rem;
        color: var(--text);
        text-decoration: none;
        white-space: nowrap;
      }

      .nav-sep { color: var(--border); }

      .nav-docs {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.9rem;
      }
      .nav-docs:hover { color: var(--text); }

      select#version-select {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        font-size: 0.85rem;
        cursor: pointer;
        outline: none;
        font-family: inherit;
      }
      select#version-select:focus { border-color: var(--accent); }

      /* ── Layout ── */
      .layout {
        display: flex;
        flex: 1;
      }

      /* ── Sidebar toggle button ── */
      .sidebar-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        color: var(--text);
        cursor: pointer;
        padding: 0.25rem 0.4rem;
        border-radius: 5px;
        flex-shrink: 0;
      }
      .sidebar-toggle:hover { background: var(--surface); }

      /* ── Sidebar overlay backdrop (mobile) ── */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        top: 49px;
        background: rgba(0, 0, 0, 0.55);
        z-index: 19;
      }
      .sidebar-overlay.visible { display: block; }

      /* ── Sidebar ── */
      aside {
        width: 220px;
        flex-shrink: 0;
        border-right: 1px solid var(--border);
        position: sticky;
        top: 49px;
        height: calc(100vh - 49px);
        overflow-y: auto;
        padding: 1.25rem 0;
        transition: width 0.2s ease, padding 0.2s ease, border 0.2s ease;
      }

      aside.collapsed {
        width: 0;
        overflow: hidden;
        padding: 0;
        border-right: none;
      }

      @media (max-width: 767px) {
        aside {
          position: fixed;
          top: 49px;
          left: 0;
          height: calc(100vh - 49px);
          z-index: 20;
          background: var(--bg);
          transform: translateX(-100%);
          transition: transform 0.25s ease;
          width: 220px !important;
          overflow-y: auto !important;
          padding: 1.25rem 0 !important;
          border-right: 1px solid var(--border) !important;
        }
        aside.open { transform: translateX(0); }
      }

      aside nav {
        display: flex;
        flex-direction: column;
      }

      aside nav a {
        display: block;
        padding: 0.35rem 1.25rem;
        font-size: 0.875rem;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.1s, background 0.1s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      aside nav a:hover { color: var(--text); background: var(--surface); }
      aside nav a.active {
        color: var(--accent);
        background: rgba(88, 166, 255, 0.08);
        font-weight: 500;
      }

      /* ── Main content ── */
      main {
        flex: 1;
        min-width: 0;
        padding: 2.5rem 3rem 4rem;
      }

      article {
        max-width: 820px;
      }

      /* ── Prose ── */
      .prose :global(h1) {
        font-size: 1.875rem;
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 1rem;
      }

      .prose :global(h2) {
        font-size: 1.35rem;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--border);
      }

      .prose :global(h3) {
        font-size: 1.1rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }

      .prose :global(h4),
      .prose :global(h5),
      .prose :global(h6) {
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 1.25rem;
        margin-bottom: 0.4rem;
      }

      .prose :global(p) {
        line-height: 1.75;
        margin-bottom: 1rem;
        color: var(--text);
      }

      .prose :global(a) { color: var(--accent); text-decoration: none; }
      .prose :global(a:hover) { text-decoration: underline; }

      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
      }

      .prose :global(li) {
        line-height: 1.75;
        margin-bottom: 0.2rem;
      }

      .prose :global(li > ul),
      .prose :global(li > ol) { margin-bottom: 0; }

      .prose :global(code) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.1em 0.35em;
        font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
        font-size: 0.875em;
      }

      .prose :global(pre) {
        background: var(--surface) !important;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.25rem;
        overflow-x: auto;
        margin-bottom: 1.25rem;
        line-height: 1.6;
      }

      .prose :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.875rem;
      }

      .prose :global(blockquote) {
        border-left: 3px solid var(--accent);
        padding: 0.25rem 0 0.25rem 1rem;
        margin: 1.25rem 0;
        color: var(--muted);
        font-style: italic;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
      }

      .prose :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.25rem;
        font-size: 0.9rem;
      }

      .prose :global(th) {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 0.5rem 0.75rem;
        text-align: left;
        font-weight: 600;
      }

      .prose :global(td) {
        border: 1px solid var(--border);
        padding: 0.5rem 0.75rem;
      }

      .prose :global(tr:nth-child(even) td) {
        background: rgba(255, 255, 255, 0.02);
      }

      .prose :global(img) {
        max-width: 100%;
        border-radius: 6px;
      }

      .prose :global(strong) { font-weight: 600; }
    </style>
  </head>
  <body>
    <header>
      <div class="header-left">
        <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation" aria-expanded="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <rect y="3" width="18" height="1.5" rx="0.75"/>
            <rect y="8.25" width="18" height="1.5" rx="0.75"/>
            <rect y="13.5" width="18" height="1.5" rx="0.75"/>
          </svg>
        </button>
        <a class="logo" href={base}>⚓️ AnchorSpec</a>
        <span class="nav-sep">/</span>
        <a class="nav-docs" href={`${base}docs/v1.3.1/getting-started`}>Docs</a>
      </div>
      <select id="version-select">
        {VERSIONS.map(v => (
          <option value={v.value} selected={v.value === version}>{v.label}</option>
        ))}
      </select>
    </header>

    <div id="sidebar-overlay" class="sidebar-overlay"></div>
    <div class="layout">
      <aside>
        <nav>
          {sidebarItems.map(item => (
            <a
              href={`${base}docs/${version}/${item.slug}`}
              class={item.slug === slug ? 'active' : ''}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </aside>

      <main>
        <article class="prose">
          <Content />
        </article>
      </main>
    </div>

    <script define:vars={{ base, slug, version }}>
      document.getElementById('version-select')?.addEventListener('change', (e) => {
        window.location.href = `${base}docs/${e.target.value}/${slug}`;
      });

      const sidebarToggle = document.getElementById('sidebar-toggle');
      const sidebar = document.querySelector('aside');
      const overlay = document.getElementById('sidebar-overlay');

      function isMobile() { return window.innerWidth < 768; }

      // Restore desktop collapsed preference
      if (!isMobile() && localStorage.getItem('sidebar-collapsed') === '1') {
        sidebar?.classList.add('collapsed');
        sidebarToggle?.setAttribute('aria-expanded', 'false');
      }

      sidebarToggle?.addEventListener('click', () => {
        if (isMobile()) {
          const isOpen = sidebar?.classList.toggle('open');
          overlay?.classList.toggle('visible', isOpen);
          sidebarToggle?.setAttribute('aria-expanded', String(isOpen));
        } else {
          const isCollapsed = sidebar?.classList.toggle('collapsed');
          sidebarToggle?.setAttribute('aria-expanded', String(!isCollapsed));
          localStorage.setItem('sidebar-collapsed', isCollapsed ? '1' : '0');
        }
      });

      overlay?.addEventListener('click', () => {
        sidebar?.classList.remove('open');
        overlay?.classList.remove('visible');
        sidebarToggle?.setAttribute('aria-expanded', 'false');
      });

      window.addEventListener('resize', () => {
        if (!isMobile()) {
          sidebar?.classList.remove('open');
          overlay?.classList.remove('visible');
        }
      });
    </script>
  </body>
</html>
