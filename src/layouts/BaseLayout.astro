---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'AnchorSpec — OpenSpec without the telemetry.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${base}favicon.ico`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href={base} class="brand">
          <span role="img" aria-label="anchor">⚓</span>
          <span>AnchorSpec</span>
        </a>
        <div class="links">
          <a href={`${base}docs/v1.3.1/getting-started`}>Docs</a>
          <a href="https://github.com/AnchorSpec/AnchorSpec/releases" target="_blank" rel="noreferrer">Releases</a>
          <a href="https://github.com/AnchorSpec/AnchorSpec" target="_blank" rel="noreferrer" class="nav-cta">GitHub</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="container">
        <div class="row">
          <span>⚓ AnchorSpec is an independent fork, not affiliated with the OpenSpec project.</span>
          <div style="display:flex;gap:18px;">
            <a href="https://github.com/AnchorSpec/AnchorSpec">GitHub</a>
            <a href="https://www.npmjs.com/package/anchorspec">NPM</a>
            <a href="https://github.com/AnchorSpec/AnchorSpec/blob/main/LICENSE">MIT</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
